DATABASE_URL="postgresql://user:password@localhost:5432/meavo_gateway"

AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3002"

GATEWAY_URL="http://localhost:3000"
MEAVO_APP_KEY=sales

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

SALES_TOOL_CARD_ID="seed-sales-tool"

# Ops File write-back (same spreadsheet the gateway imports from).
# The service account needs Editor access on the sheet for writes.
OPS_SHEET_SPREADSHEET_ID=""
OPS_SHEET_TAB_NAME="Sheet1"
GOOGLE_SERVICE_ACCOUNT_JSON=""

BLOB_READ_WRITE_TOKEN=""

# Link shown on deal pages when an Assembly record with the same DealID exists.
ASSEMBLY_URL="https://assembly.meavo.app"

# Xero Custom Connection (OAuth2 client credentials, single org).
# Scopes: accounting.invoices accounting.contacts accounting.settings.read
# Won deals create DRAFT invoices once an admin confirms the market mappings
# under Settings -> Xero. Leave empty to disable the integration.
XERO_CLIENT_ID=""
XERO_CLIENT_SECRET=""
# Optional last-resort revenue account code for invoice lines (e.g. "200").
# Per-market revenue accounts are configured under Settings -> Xero; this env
# var only applies when a market has no mapping and no default account is set.
XERO_SALES_ACCOUNT_CODE=""
