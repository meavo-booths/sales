{
  "name": "meavo-sales",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev -p 3002",
    "build": "prisma generate && next build",
    "start": "next start -p 3002",
    "lint": "next lint",
    "db:generate": "prisma generate",
    "db:push": "echo 'db:push is disabled. The shared schema lives in the meavo-db repo (github.com/meavo-booths/meavo-db) — make changes there.' && exit 1",
    "db:seed": "tsx prisma/seed.ts"
  },
  "prisma": {
    "schema": "node_modules/@meavo/db/prisma/schema.prisma"
  },
  "dependencies": {
    "@meavo/db": "github:meavo-booths/meavo-db#v0.4.0",
    "@meavo/navigation": "git+https://github.com/meavo-booths/meavo-navigation.git#v0.1.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/client": "^6.1.0",
    "@react-pdf/renderer": "^4.3.1",
    "@vercel/blob": "^2.4.0",
    "googleapis": "^144.0.0",
    "next": "^15.1.0",
    "next-auth": "^5.0.0-beta.25",
    "prisma": "^6.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
